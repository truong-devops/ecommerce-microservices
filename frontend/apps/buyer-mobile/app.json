{
  "expo": {
    "name": "DT Commerce Buyer",
    "slug": "dt-commerce-buyer",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "dtcommercebuyer",
    "userInterfaceStyle": "light",
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-web-browser",
        {
          "experimentalLauncherActivity": true
        }
      ],
      "expo-font"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "site.dtcommerce.buyermobile"
    },
    "android": {
      "package": "site.dtcommerce.buyermobile",
      "softwareKeyboardLayoutMode": "resize"
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "2194ea20-f23f-4d1b-93d4-2b070572ee51"
      }
    }
  }
}
