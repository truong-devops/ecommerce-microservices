{
  "name": "@frontend/buyer-app",
  "version": "0.1.0",
  "private": true,
  "main": "expo/AppEntry",
  "scripts": {
    "dev": "node --max-old-space-size=8192 ./node_modules/expo/bin/cli start --clear --max-workers 1",
    "start": "node --max-old-space-size=8192 ./node_modules/expo/bin/cli start --max-workers 1",
    "android": "node --max-old-space-size=8192 ./node_modules/expo/bin/cli start --android --max-workers 1",
    "ios": "node --max-old-space-size=8192 ./node_modules/expo/bin/cli start --ios --max-workers 1",
    "web": "node --max-old-space-size=8192 ./node_modules/expo/bin/cli start --web --clear --port 8088 --max-workers 1",
    "build": "node --max-old-space-size=8192 ./node_modules/expo/bin/cli export --platform web --output-dir dist --max-workers 1",
    "test": "echo 'buyer app test scaffold pending'",
    "lint": "eslint . --ext .ts,.tsx"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "expo": "~54.0.33",
    "expo-constants": "~18.0.10",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-web": "~0.21.0"
  },
  "devDependencies": {
    "@types/react": "~19.1.10",
    "babel-preset-expo": "~54.0.0",
    "eslint": "^8.57.1",
    "eslint-config-expo": "~10.0.0",
    "typescript": "^5.8.3"
  }
}
