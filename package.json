{
  "name": "ecommerce-microservices",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@10",
  "workspaces": [
    "services/*",
    "packages/*",
    "shared",
    "frontend/apps/*",
    "frontend/packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "format": "turbo run format"
  },
  "devDependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "turbo": "^2.3.3",
    "typescript": "^6.0.2"
  }
}
