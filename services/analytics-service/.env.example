APP_NAME=analytics-service
APP_ENV=development
PORT=3010
API_PREFIX=api/v1

DATABASE_URL=postgresql://ecommerce:ecommerce@localhost:5432/ecommerce
DB_SSL=false
DB_POOL_MAX=10
JWT_ACCESS_SECRET=dev-shared-jwt-access-secret-min-32-chars

REDIS_ENABLED=true
REDIS_URL=redis://localhost:6379

KAFKA_ENABLED=true
KAFKA_CLIENT_ID=analytics-service
KAFKA_BROKERS=localhost:9092
ANALYTICS_EVENTS_TOPIC=analytics.events
ANALYTICS_CONSUMER_GROUP=analytics-service-group

INGEST_DEDUPE_TTL_SECONDS=172800
