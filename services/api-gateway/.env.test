APP_NAME=api-gateway
APP_ENV=development
PORT=8080
JWT_SECRET=change-me
CORS_ALLOWED_ORIGINS=*

REQUEST_TIMEOUT=30s
SHUTDOWN_TIMEOUT=15s
RATE_LIMIT_RPS=50
RATE_LIMIT_BURST=100

AUTH_SERVICE_URL=http://host.docker.internal:18081
USER_SERVICE_URL=http://host.docker.internal:18081
PRODUCT_SERVICE_URL=http://host.docker.internal:18081
CART_SERVICE_URL=http://host.docker.internal:18081
ORDER_SERVICE_URL=http://host.docker.internal:18081
PAYMENT_SERVICE_URL=http://host.docker.internal:18081
INVENTORY_SERVICE_URL=http://host.docker.internal:18081
SHIPPING_SERVICE_URL=http://host.docker.internal:18081
REVIEW_SERVICE_URL=http://host.docker.internal:18081
NOTIFICATION_SERVICE_URL=http://host.docker.internal:18081
ANALYTICS_SERVICE_URL=http://host.docker.internal:18081

AUTH_SERVICE_TIMEOUT=8s
USER_SERVICE_TIMEOUT=8s
PRODUCT_SERVICE_TIMEOUT=8s
CART_SERVICE_TIMEOUT=8s
ORDER_SERVICE_TIMEOUT=8s
PAYMENT_SERVICE_TIMEOUT=8s
INVENTORY_SERVICE_TIMEOUT=8s
SHIPPING_SERVICE_TIMEOUT=8s
REVIEW_SERVICE_TIMEOUT=8s
NOTIFICATION_SERVICE_TIMEOUT=8s
ANALYTICS_SERVICE_TIMEOUT=8s
