APP_NAME=inventory-service
APP_ENV=development
PORT=3007
API_PREFIX=api/v1

DATABASE_URL=postgresql://ecommerce:ecommerce@localhost:5432/ecommerce
JWT_ACCESS_SECRET=dev-shared-jwt-access-secret-min-32-chars

REDIS_ENABLED=false
REDIS_URL=redis://localhost:6379

RESERVATION_DEFAULT_TTL_MINUTES=10
RESERVATION_EXPIRE_CHECK_INTERVAL_MS=15000
RESERVATION_EXPIRE_BATCH_SIZE=200

OUTBOX_DISPATCH_INTERVAL_MS=3000
OUTBOX_BATCH_SIZE=50
OUTBOX_MAX_RETRY=10

KAFKA_ENABLED=false
KAFKA_CLIENT_ID=inventory-service
KAFKA_BROKERS=localhost:9092
INVENTORY_EVENTS_TOPIC=inventory.events
KAFKA_CONSUMER_GROUP_ID=inventory-service-group

DB_MIGRATIONS_RUN=true
MIGRATION_FILE=migrations/0001_init_inventory_service.sql
