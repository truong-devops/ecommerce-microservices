APP_NAME=media-service
APP_ENV=development
PORT=8080
API_PREFIX=api/v1
JWT_ACCESS_SECRET=dev-shared-jwt-access-secret-min-32-chars

MINIO_ENDPOINT=minio:9000
MINIO_PUBLIC_ENDPOINT=127.0.0.1:12030
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=ecommerce-media
MINIO_REGION=us-east-1
MINIO_USE_SSL=false
MINIO_PUBLIC_USE_SSL=false
MINIO_PUBLIC_READ=true
OBJECT_KEY_PREFIX=products

MEDIA_UPLOAD_DEFAULT_EXPIRY_SECONDS=900
MEDIA_DOWNLOAD_DEFAULT_EXPIRY_SECONDS=900
MEDIA_MAX_EXPIRY_SECONDS=3600
