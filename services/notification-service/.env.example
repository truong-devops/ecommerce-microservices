APP_NAME=notification-service
APP_ENV=development
PORT=3009
API_PREFIX=api/v1

DATABASE_URL=postgresql://ecommerce:ecommerce@localhost:5432/ecommerce
JWT_ACCESS_SECRET=dev-shared-jwt-access-secret-min-32-chars

REDIS_ENABLED=true
REDIS_URL=redis://localhost:6379

DISPATCH_INTERVAL_MS=3000
DISPATCH_BATCH_SIZE=50
DISPATCH_MAX_RETRY=10

KAFKA_ENABLED=false
KAFKA_CLIENT_ID=notification-service
KAFKA_BROKERS=localhost:9092
NOTIFICATION_EVENTS_TOPIC=notification.events
NOTIFICATION_CONSUMER_GROUP=notification-service-group

DB_MIGRATIONS_RUN=true
MIGRATION_FILE=migrations/0001_init_notification_service.sql
