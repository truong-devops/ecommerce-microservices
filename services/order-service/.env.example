APP_NAME=order-service-go
APP_ENV=development
PORT=3002
API_PREFIX=api/v1

DATABASE_URL=postgresql://ecommerce:ecommerce@localhost:5432/ecommerce
JWT_ACCESS_SECRET=dev-shared-jwt-access-secret-min-32-chars
PRODUCT_SERVICE_BASE_URL=http://localhost:12030/api/v1
USER_SERVICE_BASE_URL=http://localhost:12011/api/v1
INTERNAL_SERVICE_TOKEN=dev-internal-service-token
DEPENDENCY_TIMEOUT_MS=5000

REDIS_ENABLED=true
REDIS_URL=redis://localhost:6379

IDEMPOTENCY_RECORD_TTL_MINUTES=60
IDEMPOTENCY_LOCK_TTL_SECONDS=30

DISPATCH_INTERVAL_MS=3000
DISPATCH_BATCH_SIZE=50
DISPATCH_MAX_RETRY=10

KAFKA_ENABLED=true
KAFKA_CLIENT_ID=order-service-go
KAFKA_BROKERS=localhost:9092
ORDER_EVENTS_TOPIC=order.events
INVENTORY_EVENTS_TOPIC=inventory.events
PAYMENT_EVENTS_TOPIC=payment.events
NOTIFICATION_EVENTS_TOPIC=notification.events
ANALYTICS_EVENTS_TOPIC=analytics.events
AUDIT_EVENTS_TOPIC=audit.events

DB_MIGRATIONS_RUN=true
MIGRATION_FILE=migrations/0001_init_order_service.sql
