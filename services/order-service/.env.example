APP_NAME=order-service
APP_ENV=development
PORT=3002
API_PREFIX=api/v1

DATABASE_URL=postgresql://ecommerce:ecommerce@postgres:5432/ecommerce
DB_SSL=false
REDIS_URL=redis://redis:6379

JWT_ACCESS_SECRET=replace-with-very-strong-access-secret-min-32chars

IDEMPOTENCY_RECORD_TTL_MINUTES=60
IDEMPOTENCY_LOCK_TTL_SECONDS=30

OUTBOX_DISPATCH_INTERVAL_MS=3000
OUTBOX_BATCH_SIZE=50
OUTBOX_MAX_RETRY=10

KAFKA_BROKERS=host.docker.internal:9092
ORDER_EVENTS_TOPIC=order.events
INVENTORY_EVENTS_TOPIC=inventory.events
PAYMENT_EVENTS_TOPIC=payment.events
NOTIFICATION_EVENTS_TOPIC=notification.events
ANALYTICS_EVENTS_TOPIC=analytics.events
AUDIT_EVENTS_TOPIC=audit.events
