APP_NAME=payment-service
APP_ENV=development
PORT=3006
API_PREFIX=api/v1

DATABASE_URL=postgresql://ecommerce:ecommerce@localhost:5432/ecommerce
JWT_ACCESS_SECRET=dev-shared-jwt-access-secret-min-32-chars
ORDER_SERVICE_BASE_URL=http://localhost:12000/api/v1
DEPENDENCY_TIMEOUT_MS=5000

REDIS_ENABLED=true
REDIS_URL=redis://localhost:6379

IDEMPOTENCY_RECORD_TTL_MINUTES=60
IDEMPOTENCY_LOCK_TTL_SECONDS=30
WEBHOOK_IDEMPOTENCY_TTL_MINUTES=1440

OUTBOX_DISPATCH_INTERVAL_MS=3000
OUTBOX_BATCH_SIZE=50
OUTBOX_MAX_RETRY=10

PAYMENT_GATEWAY=mock

KAFKA_ENABLED=true
KAFKA_CLIENT_ID=payment-service
KAFKA_BROKERS=localhost:9092
ORDER_EVENTS_TOPIC=order.events
ORDER_EVENTS_CONSUMER_GROUP=payment-service-order-events-group
PAYMENT_EVENTS_TOPIC=payment.events
NOTIFICATION_EVENTS_TOPIC=notification.events
ANALYTICS_EVENTS_TOPIC=analytics.events

DB_MIGRATIONS_RUN=true
MIGRATION_FILE=migrations/0001_init_payment_service.sql
