APP_NAME=product-service
APP_ENV=development
PORT=3003
API_PREFIX=api/v1

# Docker dev: service runs in container and connects back to host dependencies.
DATABASE_URL=mongodb://host.docker.internal:27017
DATABASE_NAME=ecommerce_product

REDIS_ENABLED=true
REDIS_URL=redis://host.docker.internal:6379

JWT_ACCESS_SECRET=replace-with-very-strong-access-secret-min-32chars

KAFKA_ENABLED=false
KAFKA_CLIENT_ID=product-service
KAFKA_BROKERS=host.docker.internal:9092
PRODUCT_EVENTS_TOPIC=product.events
ANALYTICS_EVENTS_TOPIC=analytics.events
AUDIT_EVENTS_TOPIC=audit.events

SEARCH_ENABLED=false
OPENSEARCH_URL=http://host.docker.internal:9200
OPENSEARCH_INDEX=products
OPENSEARCH_USERNAME=
OPENSEARCH_PASSWORD=
OPENSEARCH_TIMEOUT_MS=5000

MEDIA_PUBLIC_BASE_URL=http://localhost:12030/ecommerce-media
