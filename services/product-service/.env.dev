APP_NAME=product-service
APP_ENV=development
PORT=3003
API_PREFIX=api/v1

DATABASE_URL=mongodb://mongo:27017
DATABASE_NAME=ecommerce_product

REDIS_ENABLED=true
REDIS_URL=redis://redis:6379

JWT_ACCESS_SECRET=change-me-product-access-secret-min-32-chars

KAFKA_ENABLED=false
KAFKA_CLIENT_ID=product-service
KAFKA_BROKERS=host.docker.internal:9092
PRODUCT_EVENTS_TOPIC=product.events
AUDIT_EVENTS_TOPIC=audit.events

SEARCH_ENABLED=false
OPENSEARCH_URL=http://opensearch:9200
OPENSEARCH_INDEX=products
OPENSEARCH_USERNAME=
OPENSEARCH_PASSWORD=
OPENSEARCH_TIMEOUT_MS=5000
