APP_NAME=shipping-service
APP_ENV=development
PORT=3008
API_PREFIX=api/v1

DATABASE_URL=postgresql://ecommerce:ecommerce@postgres:5432/ecommerce
DB_SSL=false
REDIS_URL=redis://redis:6379

JWT_ACCESS_SECRET=change-me-shipping-access-secret-min-32

OUTBOX_DISPATCH_INTERVAL_MS=3000
OUTBOX_BATCH_SIZE=50
OUTBOX_MAX_RETRY=10

WEBHOOK_IDEMPOTENCY_TTL_MINUTES=1440

KAFKA_BROKERS=host.docker.internal:9092
SHIPPING_EVENTS_TOPIC=shipping.events
NOTIFICATION_EVENTS_TOPIC=notification.events
ANALYTICS_EVENTS_TOPIC=analytics.events
