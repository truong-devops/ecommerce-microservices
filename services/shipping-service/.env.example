APP_NAME=shipping-service
APP_ENV=development
PORT=3008
API_PREFIX=api/v1
DATABASE_URL=postgresql://ecommerce:ecommerce@postgres:5432/ecommerce
DB_SSL=false
REDIS_ENABLED=true
REDIS_URL=redis://redis:6379
JWT_ACCESS_SECRET=dev-shared-jwt-access-secret-min-32-chars
ORDER_SERVICE_BASE_URL=http://localhost:12000/api/v1
DEPENDENCY_TIMEOUT_MS=5000
SHIPPING_WEBHOOK_SIGNING_SECRET=dev-shipping-webhook-signing-secret
NEXUS_ENABLED=false
NEXUS_WEBHOOK_ENABLED=false
NEXUS_BASE_URL=https://ops.nexus-ex.site
NEXUS_PARTNER_CODE=
NEXUS_API_KEY=
NEXUS_API_SECRET=
NEXUS_WEBHOOK_SECRET=
NEXUS_MERCHANT_MAPPING_FILE=./config/nexus-merchant-mappings.example.json
NEXUS_AUTO_CREATE_PICKUP=false
NEXUS_DEFAULT_SERVICE_TYPE=STANDARD
NEXUS_DEFAULT_PICKUP_TYPE=PICKUP
NEXUS_DEFAULT_PAYER=RECEIVER
NEXUS_DEFAULT_WEIGHT_GRAM=500
NEXUS_DEFAULT_LENGTH_CM=20
NEXUS_DEFAULT_WIDTH_CM=15
NEXUS_DEFAULT_HEIGHT_CM=10
NEXUS_REQUEST_TIMEOUT_MS=10000
OUTBOX_DISPATCH_INTERVAL_MS=3000
OUTBOX_BATCH_SIZE=50
OUTBOX_MAX_RETRY=10
WEBHOOK_IDEMPOTENCY_TTL_MINUTES=1440
KAFKA_ENABLED=true
KAFKA_CLIENT_ID=shipping-service
KAFKA_BROKERS=kafka:9092
ORDER_EVENTS_TOPIC=order.events
ORDER_EVENTS_CONSUMER_GROUP=shipping-service-order-events-group
SHIPPING_EVENTS_TOPIC=shipping.events
NOTIFICATION_EVENTS_TOPIC=notification.events
ANALYTICS_EVENTS_TOPIC=analytics.events
DB_MIGRATIONS_RUN=true
MIGRATION_FILE=/migrations/0001_init_shipping_service.sql
